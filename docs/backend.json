
{
  "entities": {
    "Service": {
      "title": "Service",
      "description": "A service package offered by the business.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "string" },
        "description": { "type": "string" },
        "iconName": { "type": "string" },
        "imageUrl": { "type": "string", "description": "Base64 or URL of the service image." },
        "features": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "ownerId": { "type": "string" }
      },
      "required": ["name", "price", "description", "iconName", "ownerId"]
    },
    "PortfolioItem": {
      "title": "PortfolioItem",
      "description": "An image demonstrating past work or results.",
      "type": "object",
      "properties": {
        "imageUrl": { "type": "string" },
        "title": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "ownerId": { "type": "string" }
      },
      "required": ["imageUrl", "ownerId"]
    },
    "Booking": {
      "title": "Booking",
      "description": "A service request from a customer.",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "whatsapp": { "type": "string" },
        "address": { "type": "string" },
        "service": { "type": "string" },
        "notes": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Selesai"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "businessId": { "type": "string" }
      },
      "required": ["fullName", "whatsapp", "address", "service", "status", "businessId"]
    },
    "BusinessSettings": {
      "title": "BusinessSettings",
      "description": "General settings for the business content and branding.",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string" },
        "name": { "type": "string" },
        "whatsapp": { "type": "string" },
        "address": { "type": "string" },
        "email": { "type": "string" },
        "mapEmbedUrl": { "type": "string" },
        "mapDirectUrl": { "type": "string" },
        "logoText": { "type": "string" },
        "logoAccentText": { "type": "string" },
        "logoUrl": { "type": "string" },
        "logoHeight": { "type": "string" },
        "fontFamily": { "type": "string", "description": "Selected Google Font name." },
        "heroBadge": { "type": "string" },
        "heroTitle": { "type": "string" },
        "heroTitleImageUrl": { "type": "string", "description": "Image to replace the hero title text." },
        "heroTitleImageHeight": { "type": "string" },
        "heroSubtitle": { "type": "string" },
        "heroImageUrl": { "type": "string" },
        "heroImagePosition": { "type": "string" },
        "aboutTitle": { "type": "string" },
        "aboutContent": { "type": "string" },
        "servicesSectionBadge": { "type": "string" },
        "servicesSectionTitle": { "type": "string" },
        "servicesSectionSubtitle": { "type": "string" },
        "privacyPolicy": { "type": "string" },
        "socialInstagram": { "type": "string" },
        "socialFacebook": { "type": "string" },
        "socialYoutube": { "type": "string" },
        "socialTiktok": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["email"]
  },
  "firestore": {
    "/businesses/{businessId}/services/{serviceId}": {
      "schema": "Service",
      "description": "Collection of services for a specific business."
    },
    "/businesses/{businessId}/portfolio/{itemId}": {
      "schema": "PortfolioItem",
      "description": "Collection of portfolio images for a specific business."
    },
    "/businesses/{businessId}/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Collection of bookings for a specific business."
    },
    "/businesses/{businessId}/settings/profile": {
      "schema": "BusinessSettings",
      "description": "Settings for a specific business."
    }
  }
}
