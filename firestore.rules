
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Aturan global untuk bisnis utama dengan ID 'main'
    match /businesses/main {
      // Izinkan publik membaca data profil bisnis 'main'
      allow read: if true;
      // Hanya admin terotentikasi yang bisa mengubah data profil
      allow write: if request.auth != null;

      // Izinkan akses ke sub-jalur layanan: Publik bisa baca, Admin bisa tulis
      match /services/{serviceId} {
        allow read: if true;
        allow write: if request.auth != null;
      }

      // Izinkan akses ke pengaturan profil: Publik bisa baca, Admin bisa tulis
      match /settings/profile {
        allow read: if true;
        allow write: if request.auth != null;
      }

      // Aturan khusus untuk pesanan (bookings)
      match /bookings/{bookingId} {
        // Pengunjung hanya bisa buat pesanan (create), tidak bisa lihat daftar (list)
        allow create: if true;
        // Hanya admin yang bisa baca (get/list) dan kelola (update/delete)
        allow read, update, delete: if request.auth != null;
      }
    }
    
    // Tolak akses ke dokumen lain secara default demi keamanan
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
