
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Fungsi pembantu untuk cek login
    function isAuthenticated() {
      return request.auth != null;
    }

    // Services: Publik bisa melihat, Admin bisa edit
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Bookings: Publik bisa kirim, Admin bisa kelola
    match /bookings/{bookingId} {
      allow create: if true;
      allow read, update, delete: if isAuthenticated();
    }

    // Settings: Publik bisa melihat (PENTING untuk Logo & Nama), Admin bisa edit
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    
    // Default: Tolak akses lainnya
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
