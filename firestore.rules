
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Aturan global untuk bisnis utama dengan ID 'main'
    match /businesses/main {
      // Izinkan publik membaca data profil bisnis 'main'
      allow read: if true;
      // Hanya admin terotentikasi yang bisa mengubah data profil
      allow write: if request.auth != null;

      // Izinkan akses ke semua sub-jalur di bawah 'main' (layanan, pengaturan, dll)
      match /{allSubpaths=**} {
        allow read: if true;
        allow write: if request.auth != null;
      }

      // Aturan khusus untuk pesanan (bookings)
      match /bookings/{bookingId} {
        // Pengunjung bisa buat pesanan
        allow create: if true;
        // Hanya admin yang bisa baca dan kelola daftar pesanan
        allow read, update, delete: if request.auth != null;
      }
    }
    
    // Tolak akses ke dokumen lain secara default demi keamanan
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
