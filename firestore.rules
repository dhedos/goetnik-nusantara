
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Aturan untuk bisnis utama dengan ID 'main'
    match /businesses/main {
      // Izinkan siapapun membaca info bisnis (logo, nama, dll)
      allow read: if true;
      // Hanya admin yang bisa menulis info bisnis
      allow write: if request.auth != null;

      // Aturan untuk sub-koleksi layanan
      match /services/{serviceId} {
        allow read: if true;
        allow write: if request.auth != null;
      }

      // Aturan untuk sub-koleksi pengaturan profil
      match /settings/profile {
        allow read: if true;
        allow write: if request.auth != null;
      }

      // Aturan untuk pesanan (bookings)
      match /bookings/{bookingId} {
        // Pengunjung bisa buat pesanan
        allow create: if true;
        // Hanya admin yang bisa baca dan kelola pesanan
        allow read, update, delete: if request.auth != null;
      }
    }
    
    // Tolak akses ke dokumen lain secara default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
