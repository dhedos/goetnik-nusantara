
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function
    function isOwner(businessId) {
      return request.auth != null && request.auth.uid == businessId;
    }

    // Business Data: Public can read, only Owner can write
    match /businesses/{businessId}/{document=**} {
      allow read: if true;
      allow write: if isOwner(businessId);
    }

    // Bookings special case: Public can create, only Owner can read/update
    match /businesses/{businessId}/bookings/{bookingId} {
      allow create: if true;
      allow read, update, delete: if isOwner(businessId);
    }
    
    // Default: Deny all
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
