
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function untuk cek kepemilikan bisnis
    function isOwner(businessId) {
      return request.auth != null && request.auth.uid == businessId;
    }

    // Aturan untuk dokumen Bisnis Utama
    match /businesses/{businessId} {
      allow read: if true;
      allow write: if isOwner(businessId);
    }

    // Aturan untuk Layanan (Services)
    match /businesses/{businessId}/services/{serviceId} {
      allow read: if true;
      allow write: if isOwner(businessId);
    }

    // Aturan untuk Pengaturan Profil (Settings)
    match /businesses/{businessId}/settings/profile {
      allow read: if true;
      allow write: if isOwner(businessId);
    }

    // Aturan untuk Pesanan (Bookings)
    match /businesses/{businessId}/bookings/{bookingId} {
      allow create: if true;
      allow read, update, delete: if isOwner(businessId);
    }
    
    // Default: Tolak semua akses lainnya untuk keamanan
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
