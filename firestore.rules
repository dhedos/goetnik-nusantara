
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Rule khusus untuk bisnis utama agar sinkronisasi lancar
    match /businesses/main {
      // Publik bisa membaca profil bisnis utama
      allow read: if true;
      // Admin bisa mengelola profil bisnis utama
      allow write: if request.auth != null;

      // Aturan untuk semua sub-koleksi di bawah 'main'
      match /services/{serviceId} {
        allow read: if true;
        allow write: if request.auth != null;
      }

      match /settings/profile {
        allow read: if true;
        allow write: if request.auth != null;
      }

      // Khusus pesanan: Publik bisa kirim (create), Admin bisa baca/kelola
      match /bookings/{bookingId} {
        allow create: if true;
        allow read, update, delete: if request.auth != null;
      }
    }
    
    // Default deny untuk jalur lain demi keamanan
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
