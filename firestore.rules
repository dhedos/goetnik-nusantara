rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Aturan untuk bisnis utama 'main'
    match /businesses/main {
      // Izinkan publik membaca data profil bisnis utama
      allow read: if true;
      // Izinkan admin yang login untuk menulis data profil bisnis utama
      allow write: if request.auth != null;

      // Aturan untuk semua sub-koleksi (services, bookings, settings, dll)
      match /{allPaths=**} {
        allow read: if true;
        allow write: if request.auth != null;
      }

      // Aturan khusus: Publik bisa kirim pesanan (create), Admin bisa kelola (read/write)
      match /bookings/{bookingId} {
        allow create: if true;
      }
    }
    
    // Default deny untuk jalur lain demi keamanan
    match /{document=**} {
      allow read, write: if false;
    }
  }
}