
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Fungsi pembantu untuk cek admin
    function isAdmin() {
      return request.auth != null;
    }

    // Aturan untuk bisnis tunggal dengan ID 'main'
    match /businesses/{businessId} {
      // Siapapun bisa baca profil dan layanan bisnis
      allow read: if true;
      // Hanya admin yang bisa mengelola data bisnis utama
      allow write: if isAdmin();

      // Aturan eksplisit untuk sub-koleksi layanan
      match /services/{serviceId} {
        allow read: if true;
        allow write: if isAdmin();
      }

      // Aturan eksplisit untuk pengaturan profil
      match /settings/profile {
        allow read: if true;
        allow write: if isAdmin();
      }

      // Aturan untuk pesanan (bookings)
      match /bookings/{bookingId} {
        // Pengunjung bisa buat pesanan
        allow create: if true;
        // Hanya admin yang bisa baca dan kelola pesanan
        allow read, update, delete: if isAdmin();
      }
    }
    
    // Tolak akses ke dokumen lain secara default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
