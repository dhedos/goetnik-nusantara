
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Fungsi pembantu untuk cek admin
    function isAdmin() {
      return request.auth != null;
    }

    // Izinkan akses ke koleksi businesses dan semua dokumen di dalamnya
    match /businesses/{businessId} {
      // Siapapun bisa baca profil bisnis utama
      allow read: if true;
      // Hanya admin yang bisa menulis ke dokumen bisnis utama
      allow write: if isAdmin();

      // Aturan eksplisit untuk sub-koleksi
      match /services/{serviceId} {
        allow read: if true;
        allow write: if isAdmin();
      }

      match /settings/profile {
        allow read: if true;
        allow write: if isAdmin();
      }

      match /bookings/{bookingId} {
        // Pengunjung bisa buat pesanan
        allow create: if true;
        // Hanya admin yang bisa mengelola (baca/edit/hapus) pesanan
        allow read, update, delete: if isAdmin();
      }
    }
    
    // Tolak akses ke dokumen lain secara default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
