rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Jalur utama untuk identitas bisnis tunggal 'main'
    match /businesses/main {
      // Izinkan publik membaca data profil dan layanan
      allow read: if true;
      // Izinkan admin yang terautentikasi mengelola dokumen utama 'main'
      allow write: if request.auth != null;

      // Aturan untuk semua sub-koleksi dan dokumen di bawahnya (services, settings, profile, dll)
      match /{allPaths=**} {
        allow read: if true;
        allow write: if request.auth != null;
      }

      // Aturan khusus pesanan: Publik bisa kirim (create), Admin bisa baca/kelola
      match /bookings/{bookingId} {
        allow create: if true;
        allow read, update, delete: if request.auth != null;
      }
    }
    
    // Default deny untuk jalur lain di luar bisnis utama demi keamanan
    match /{document=**} {
      allow read, write: if false;
    }
  }
}