rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Aturan utama untuk koleksi bisnis
    match /businesses/{businessId} {
      // Akses publik untuk membaca profil bisnis
      allow read: if true;
      // Akses admin untuk menulis/mengubah data bisnis utama
      allow write: if request.auth != null;

      // Aturan untuk semua sub-koleksi di bawah bisnis (settings, services, dll)
      match /{allPaths=**} {
        allow read: if true;
        allow write: if request.auth != null;
      }

      // Aturan khusus untuk Pesanan (Bookings)
      // Pengunjung publik diperbolehkan membuat pesanan baru
      match /bookings/{bookingId} {
        allow create: if true;
        // Hanya admin yang bisa membaca, memperbarui, atau menghapus pesanan
        allow read, update, delete: if request.auth != null;
      }
    }
    
    // Default deny untuk semua jalur lain demi keamanan
    match /{document=**} {
      allow read, write: if false;
    }
  }
}