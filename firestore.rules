
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Fungsi pembantu untuk cek admin
    function isAdmin() {
      return request.auth != null;
    }

    // Aturan untuk koleksi bisnis utama
    match /businesses/{businessId} {
      // Semua orang bisa baca profil bisnis dan layanan
      allow read: if true;
      // Hanya admin yang bisa ubah data profil
      allow write: if isAdmin();

      match /services/{serviceId} {
        allow read: if true;
        allow write: if isAdmin();
      }

      match /settings/profile {
        allow read: if true;
        allow write: if isAdmin();
      }

      match /bookings/{bookingId} {
        // Pengunjung bisa buat pesanan
        allow create: if true;
        // Hanya admin yang bisa kelola pesanan
        allow read, update, delete: if isAdmin();
      }
    }
    
    // Tolak akses ke dokumen lain secara default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
